[user]
  name = "Mathias Jean Johansen"
  email = mathias@mjj.io
  signingKey = A3CDD4CCFF4E55AC
[github]
  user = majjoha
[core]
  editor = nvim
  excludesfile = ~/.config/git/gitignore
  untrackedCache = true
  whitespace = space-before-tab,-indent-with-non-tab,trailing-space
  pager = delta
[commit]
  template = ~/.config/git/message
  gpgSign = true
[init]
  defaultBranch = main
[credential]
  helper = osxkeychain
[color]
  branch = auto
  interactive = auto
  status = auto
  ui = auto
[diff]
  mnemonicprefix = true
  algorithm = histogram
[branch]
  autosetupmerge = true
  sort = -committerdate
[submodule]
  fetchJobs = 4
[status]
  branch = 1
  short = 1
[apply]
  whitespace = warn
[push]
  default = upstream
  autoSetupRemote = true
[pull]
  rebase = true
[rerere]
  enabled = true
[alias]
  branch-name = !"git for-each-ref --format=\"%(refname:short)\" $(git symbolic-ref HEAD)"
  cleanup = "!f() { \
    echo 'Pruning remote-tracking branches...'; \
    git fetch --prune; \
    gone=$(git branch -vv | grep ': gone]' | awk '{print $1}'); \
    if [ -z \"$gone\" ]; then \
      echo 'No stale branches to delete.'; \
    else \
      echo \"Deleting: $gone\"; \
      echo \"$gone\" | xargs git branch -D; \
    fi; \
  }; f"
  last-week = !git shortlog --since='1 week ago' --pretty=format:'%cD: %s' --author="$(git config user.email)" --no-merges
  pr = !"gh pr create --web"
  preview = !"git fetch && git diff ^origin/main"
  standup = !git shortlog --since=yesterday --no-merges --author="$(git config user.email)"
  undo = reset --soft HEAD^
  unpushed = log --branches --not --remotes --simplify-by-decoration --decorate --oneline
  unstage = reset HEAD
  wip = !git add -u && git commit -m "wip"
  zpush = !"git push -u origin `git branch-name`:majjoha/`git branch-name`"
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  line-numbers = true
  side-by-side = true
  light = true
  syntax-theme = none
  file-style = "#2f2f2d"
  file-decoration-style = none
  file-modified-label = "[modified]"
  file-added-label = "[added]"
  file-removed-label = "[removed]"
  file-renamed-label = "[renamed]"
  file-copied-label = "[copied]"
  minus-style = "#2f2f2d" "#e6cdc3"
  minus-emph-style = "#2f2f2d" "#d4a794"
  plus-style = "#2f2f2d" "#d6dabe"
  plus-emph-style = "#2f2f2d" "#bcc48e"
  hunk-header-style = "#6f6359" italic
  hunk-header-decoration-style = "#cbbda9" ul
  line-numbers-minus-style = "#9f5032"
  line-numbers-plus-style = "#7c7e44"
  line-numbers-zero-style = "#cbbda9"
[tag]
  sort = version:refname
[help]
  autocorrect = prompt
