set main-view = \
  date:relative \
  id:yes \
  author:width=25 \
  commit-title:yes,refs=yes

set vertical-split = horizontal
set split-view-height = 75%

# Absolute path because diff-highlight is not on PATH (so `= true` fails).
set diff-highlight = /opt/homebrew/share/git-core/contrib/diff-highlight/diff-highlight
set diff-options = -m --first-parent
set ignore-space = some
set tab-size = 2
set line-graphics = utf-8

color cursor color7 color11
color cursor-blur color7 color10
color title-focus color7 color10
color title-blur color7 color10
color status color7 default
color author color7 default
color date color6 default
color diff-header color7 default
color commit color7 default
color "    Co-authored-by:"	color7	default

# Vim-inspired key bindings
bind generic g  none
bind generic gg move-first-line
bind generic <C-f> move-page-down
bind generic <C-b> move-page-up
